# Wrapper for Trino CLI inside the trino-ci-trino container.
# Usage:
#   ./trino                                    # interactive
#   ./trino --output-format CSV <<'EOF'        # heredoc / batch
#   SELECT 1;
#   EOF
#   echo "SELECT 1;" | ./trino                 # piped input
#   ./trino --help                             # pass-through flags

CONTAINER="trino-ci-trino"

if [ -t 0 ]; then
  # stdin is a terminal — interactive mode
  exec docker exec -it "$CONTAINER" trino "$@"
else
  # stdin is piped or redirected — non-interactive
  exec docker exec -i "$CONTAINER" trino "$@"
fi
